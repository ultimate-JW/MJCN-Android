<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MJCN" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorOnSecondary">@color/primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>

    <style name="Theme.MJCN.Splash" parent="Theme.MJCN">
        <item name="android:colorBackground">@color/primary</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:navigationBarColor">@color/primary</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.MJCN.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="backgroundTint">@color/btn_primary</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.MJCN.Button.Kakao" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/btn_kakao_text</item>
        <item name="android:background">@drawable/bg_btn_kakao</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- TextInput Styles -->
    <style name="Widget.MJCN.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="boxStrokeColor">@color/input_stroke</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxCornerRadiusTopStart">100dp</item>
        <item name="boxCornerRadiusTopEnd">100dp</item>
        <item name="boxCornerRadiusBottomStart">100dp</item>
        <item name="boxCornerRadiusBottomEnd">100dp</item>
        <item name="hintEnabled">false</item>
    </style>

    <!-- 바텀시트 둥근 모서리 스타일 -->
    <style name="Theme.MJCN.BottomSheet" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.MJCN.BottomSheet</item>
        <item name="colorPrimary">@color/primary</item>
    </style>

    <style name="Widget.MJCN.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.MJCN.BottomSheet</item>
        <item name="android:background">@color/background</item>
    </style>

    <style name="ShapeAppearance.MJCN.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.MJCN.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
    </style>
</resources>
