<?xml version="1.0" encoding="utf-8"?>
<!-- [수정] 피그마 디자인 기준 + fragment_signup_email_verify/id_pw 스타일 통일 -->
<!-- paddingTop 60dp, 제목 30sp bold, 라벨 14sp text_secondary, 입력 14sp, 버튼 text_secondary -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="60dp"
    android:paddingBottom="24dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline50"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <!-- 제목: 30sp bold, text_primary -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/signup_major_title"
        android:textColor="@color/text_primary"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 설명: 14sp, text_primary -->
    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/signup_major_desc"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ======= 대학 ======= -->
    <!-- 라벨: 14sp, text_secondary, 첫 라벨 marginTop 48dp -->
    <TextView
        android:id="@+id/tv_college_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/college_label"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_desc"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 입력 필드: marginTop 6dp, textSize 14sp -->
    <TextView
        android:id="@+id/tv_college"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:hint="@string/college_hint"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_college_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ======= 학부/학과 ======= -->
    <!-- 라벨: marginTop 24dp -->
    <TextView
        android:id="@+id/tv_department_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/department_label"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_college"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_department"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:hint="@string/department_hint"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_department_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ======= 전공 ======= -->
    <TextView
        android:id="@+id/tv_major_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/major_label"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_department"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_major"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_input_field"
        android:gravity="center_vertical"
        android:hint="@string/major_hint"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_major_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ======= 이전 버튼 (아웃라인 스타일) ======= -->
    <Button
        android:id="@+id/btn_prev"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_btn_outline"
        android:text="@string/prev"
        android:textColor="@color/primary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guideline50" />

    <!-- ======= 다음 버튼: textColor text_secondary (기존 화면과 동일) ======= -->
    <Button
        android:id="@+id/btn_next"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_btn_primary"
        android:enabled="false"
        android:text="@string/next"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/guideline50"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
