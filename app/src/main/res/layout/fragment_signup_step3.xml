<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="60dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/signup_interest_title"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/signup_interest_desc"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 관심 분야 칩 목록: ConstraintLayout Flow 헬퍼로 자동 줄바꿈 -->
        <androidx.constraintlayout.helper.widget.Flow
            android:id="@+id/interests_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            app:flow_horizontalGap="10dp"
            app:flow_verticalGap="12dp"
            app:flow_horizontalStyle="packed"
            app:flow_horizontalBias="0"
            app:flow_wrapMode="chain"
            app:constraint_referenced_ids="chip_it,chip_design,chip_marketing,chip_finance,chip_education,chip_public,chip_medical,chip_media,chip_architecture,chip_sports,chip_research,chip_other"
            app:layout_constraintTop_toBottomOf="@id/tv_desc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/chip_it"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="IT/개발"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_design"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="디자인"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_marketing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="마케팅/광고"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_finance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="금융/회계"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_education"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="교육"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_public"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="공기업/공공기관"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_medical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="의료/바이오"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_media"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="미디어/콘텐츠"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_architecture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="건축/공간"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_sports"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="스포츠/예술"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_research"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="연구/R&amp;D"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chip_other"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_interest_chip"
            android:gravity="center"
            android:maxLines="1"
            android:singleLine="true"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp"
            android:text="기타(직접 입력)"
            android:textColor="@color/interest_text_color"
            android:textSize="14sp" />

        <!-- 키보드 표시 시 EditText 하단 기준선. 코드에서 keyboard_top - 19dp 위치로 동적 이동 -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guide_input_bottom"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="horizontal"
            app:layout_constraintGuide_end="0dp" />

        <!-- 기타(직접 입력) 선택 시 노출되는 입력칸
             - 상단을 기타 칩(=interests_container 마지막 행) 바로 아래 10dp에 고정
             - layout_height="0dp" + layout_constraintHeight_max="285dp": 최대 285dp, 공간 부족 시 자동 축소
             - layout_constraintVertical_bias="0.0": 상단 정렬(EditText는 항상 기타 칩 바로 밑) -->
        <EditText
            android:id="@+id/et_other_interest"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintHeight_max="285dp"
            android:background="@drawable/bg_interest_input"
            android:gravity="top|start"
            android:hint="@string/signup_interest_other_hint"
            android:imeOptions="actionDone"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLength="100"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/font_color3"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/interests_container"
            app:layout_constraintBottom_toTopOf="@id/btn_prev"
            app:layout_constraintVertical_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_btn_outline"
            app:backgroundTint="@null"
            android:text="@string/prev"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_next" />

        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_primary"
            android:enabled="false"
            android:text="@string/next"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintHorizontal_weight="2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_prev"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
