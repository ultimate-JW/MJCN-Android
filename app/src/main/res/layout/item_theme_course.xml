<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bg_theme_course_item"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/tv_course_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="12dp"
        android:duplicateParentState="true"
        android:fontFamily="@font/pretendard_semibold"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/course_item_text"
        android:textSize="15sp"
        app:layout_constraintEnd_toStartOf="@id/iv_course_toggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_course_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:duplicateParentState="true"
        android:fontFamily="@font/pretendard_regular"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/course_item_subtitle"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/iv_course_toggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_course_title" />

    <ImageView
        android:id="@+id/iv_course_toggle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="18dp"
        android:contentDescription="@null"
        android:duplicateParentState="true"
        android:src="@drawable/ic_course_toggle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
