<?xml version="1.0" encoding="utf-8"?>
<!-- 수강 이력 과목 카드 아이템: 과목명, 학과/단과대 정보, +버튼, 성적 선택칸(선택 시 노출) -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_course_card"
    android:paddingStart="18dp"
    android:paddingEnd="14dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp">

    <TextView
        android:id="@+id/tv_course_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_add_course"
        tools:text="AI프로그래밍" />

    <TextView
        android:id="@+id/tv_course_meta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/font_color2"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/tv_course_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_add_course"
        tools:text="반도체 ICT대학 · 컴퓨터정보통신공학부 · 컴퓨터공학과" />

    <ImageView
        android:id="@+id/btn_add_course"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_plus_circle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/tv_course_meta"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_grade_select"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_grade_select"
        android:gravity="center"
        android:hint="@string/signup_course_grade_hint"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/font_color3"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_course_meta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
