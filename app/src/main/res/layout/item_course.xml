<?xml version="1.0" encoding="utf-8"?>
<!-- 수강 이력 과목 카드:
     - 미선택: 72dp 높이, 카드 왼쪽 18dp/위 12dp 에 과목명, + 버튼은 위 24dp/오른쪽 18dp.
     - 선택: 성적 칸이 카드 위 70dp / 아래 12dp / 양옆 18dp 위치에 노출 → 카드가 자연스럽게 늘어남. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_course_card"
    android:minHeight="72dp">

    <TextView
        android:id="@+id/tv_course_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@id/btn_add_course"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="AI프로그래밍" />

    <TextView
        android:id="@+id/tv_course_meta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/font_color2"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@id/btn_add_course"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_course_name"
        tools:text="반도체 ICT대학 · 컴퓨터정보통신공학부 · 컴퓨터공학과" />

    <ImageView
        android:id="@+id/btn_add_course"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="18dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_plus_circle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 성적 선택 칸: 카드 위 70dp / 아래 12dp / 양옆 18dp. visibility=gone 일 땐 카드는 minHeight 72dp 유지. -->
    <TextView
        android:id="@+id/tv_grade_select"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="70dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_search_field"
        android:gravity="start|center_vertical"
        android:hint="@string/signup_course_grade_hint"
        android:paddingStart="24dp"
        android:paddingTop="19.5dp"
        android:paddingEnd="24dp"
        android:paddingBottom="19.5dp"
        android:textColor="@color/text_primary"
        android:textColorHint="#CCCCCC"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0" />

</androidx.constraintlayout.widget.ConstraintLayout>
