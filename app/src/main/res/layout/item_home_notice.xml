<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="18dp"
        android:paddingVertical="18dp"
        android:background="@drawable/bg_white_radius12"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_category_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            >

            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12dp"
                android:fontFamily="@font/pretendard_medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_team"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            app:layout_constraintStart_toEndOf="@id/layout_category_chip"
            app:layout_constraintTop_toTopOf="@id/layout_category_chip"
            app:layout_constraintBottom_toBottomOf="@id/layout_category_chip"
            android:fontFamily="@font/pretendard_regular"
            android:textSize="12dp"
            android:textColor="@color/font_color2" />

        <TextView
            android:id="@+id/tv_dot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            app:layout_constraintStart_toEndOf="@id/tv_team"
            app:layout_constraintTop_toTopOf="@id/layout_category_chip"
            app:layout_constraintBottom_toBottomOf="@id/layout_category_chip"
            android:text="·"
            android:fontFamily="@font/pretendard_regular"
            android:textSize="12dp"
            android:textColor="@color/font_color2" />

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            app:layout_constraintStart_toEndOf="@id/tv_dot"
            app:layout_constraintTop_toTopOf="@id/layout_category_chip"
            app:layout_constraintBottom_toBottomOf="@id/layout_category_chip"
            android:fontFamily="@font/pretendard_regular"
            android:textSize="12dp"
            android:textColor="@color/font_color2" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:lines="1"
            android:ellipsize="end"
            android:fontFamily="@font/pretendard_bold"
            android:maxLines="2"
            android:textColor="@color/font_color1"
            android:textSize="16dp"
            app:layout_constraintEnd_toStartOf="@id/btn_bookmark"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_category_chip" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_bookmark"
            android:layout_width="32dp"
            android:layout_height="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@drawable/ic_bookmark" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
