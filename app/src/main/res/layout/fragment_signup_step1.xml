<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="60dp"
        android:paddingBottom="24dp">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline50"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/signup_basic_title"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/signup_basic_desc"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 이름 -->
        <TextView
            android:id="@+id/tv_name_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="이름"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_desc"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/et_name"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_field"
            android:hint="@string/name_hint"
            android:inputType="textPersonName"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_name_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_name_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="4dp"
            android:text="@string/name_error"
            android:textColor="@color/error"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/et_name"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 학년 / 학기 -->
        <TextView
            android:id="@+id/tv_grade_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="6dp"
            android:text="학년"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_name_error"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline50" />

        <TextView
            android:id="@+id/tv_semester_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="6dp"
            android:text="학기"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_name_error"
            app:layout_constraintStart_toEndOf="@id/guideline50"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_grade"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:hint="@string/grade_hint"
            android:paddingStart="24dp"
            android:paddingEnd="20dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:focusable="false"
            android:clickable="true"
            app:layout_constraintTop_toBottomOf="@id/tv_grade_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline50" />

        <TextView
            android:id="@+id/tv_semester"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:hint="@string/semester_hint"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:focusable="false"
            android:clickable="true"
            app:layout_constraintTop_toBottomOf="@id/tv_semester_label"
            app:layout_constraintStart_toEndOf="@id/guideline50"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 입학 연도 -->
        <TextView
            android:id="@+id/tv_entrance_year_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/entrance_year_label"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_grade"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_entrance_year"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:hint="@string/grad_year_hint"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:focusable="false"
            android:clickable="true"
            app:layout_constraintTop_toBottomOf="@id/tv_entrance_year_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 졸업 희망 시기(선택) -->
        <TextView
            android:id="@+id/tv_graduation_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/graduation_label"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tv_entrance_year"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_graduation"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_field"
            android:gravity="center_vertical"
            android:hint="@string/grad_year_hint"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:textSize="14sp"
            android:focusable="false"
            android:clickable="true"
            app:layout_constraintTop_toBottomOf="@id/tv_graduation_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_disabled"
            android:enabled="false"
            android:text="@string/next"
            android:textColor="@color/text_disabled"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
