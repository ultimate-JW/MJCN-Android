<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- 제목은 흰 카드 바깥 -->
    <TextView
        android:id="@+id/tv_program_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/pretendard_bold"
        android:textColor="@color/font_color1"
        android:textSize="18sp" />

    <!-- 흰 카드 (3 서브카드 + 신청 버튼만 포함) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_white_radius12"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- 어떤 사업? -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_theme_assessment_item"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingVertical="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard_semibold"
                android:text="📌 어떤 사업?"
                android:textColor="@color/font_color1"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_program_what"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/pretendard_regular"
                android:lineSpacingExtra="4dp"
                android:textColor="#888888"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 혜택 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_theme_assessment_item"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingVertical="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard_semibold"
                android:text="💰 혜택"
                android:textColor="@color/font_color1"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_program_benefits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/pretendard_regular"
                android:lineSpacingExtra="4dp"
                android:textColor="#888888"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 자격요건 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_theme_assessment_item"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingVertical="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard_semibold"
                android:text="✅ 자격요건"
                android:textColor="@color/font_color1"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_program_requirements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/pretendard_regular"
                android:lineSpacingExtra="4dp"
                android:textColor="#888888"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 신청 사이트 바로가기 -->
        <LinearLayout
            android:id="@+id/btn_apply"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_btn_primary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendard_semibold"
                android:text="신청 사이트 바로가기"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="4dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_external_link" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
