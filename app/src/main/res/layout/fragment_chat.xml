<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.ultimatejw.mjcn.ui.main.chat.ChatViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/sheet_background">

        <!-- 헤더 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_header"
            android:layout_width="0dp"
            android:layout_height="136dp"
            android:background="@color/background"
            android:paddingHorizontal="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="AI 채팅"
                android:textColor="@color/font_color1"
                android:fontFamily="@font/pretendard_bold"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/tv_subtitle"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="AI 비서 띵똥이에게 다 물어보세요!"
                android:textColor="@color/font_color2"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
        <!-- 스크롤 영역 (AI 카드 + 이전 대화) -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/layout_header"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- AI 입력 카드 -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/card_ai"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:background="@drawable/bg_white_radius12"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/iv_ai_icon"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_send_button"
                        android:text="@string/chat_ai_icon"
                        android:textColor="@color/black"
                        android:textSize="30sp"
                        android:gravity="center"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tv_ai_welcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/chat_welcome"
                        android:fontFamily="@font/pretendard_bold"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/iv_ai_icon"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tv_suggestion1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_e8e6fb_radius33"
                        android:gravity="center"
                        android:padding="14dp"
                        android:text="@string/chat_suggestion1"
                        android:textColor="@color/point_color1"
                        android:textSize="14sp"
                        app:layout_constraintTop_toBottomOf="@id/tv_ai_welcome"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tv_suggestion2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_e8e6fb_radius33"
                        android:gravity="center"
                        android:padding="14dp"
                        android:text="@string/chat_suggestion2"
                        android:textColor="@color/point_color1"
                        android:textSize="14sp"
                        app:layout_constraintTop_toBottomOf="@id/tv_suggestion1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- 입력창 -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layout_input"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_chat_input"
                        app:layout_constraintTop_toBottomOf="@id/tv_suggestion2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <ImageButton
                            android:id="@+id/btn_plus"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="10dp"
                            android:background="@android:color/transparent"
                            android:src="@drawable/ic_plus"
                            android:enabled="false"
                            android:alpha="0.4"
                            android:contentDescription="첨부"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />

                        <EditText
                            android:id="@+id/et_message"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:hint="띵똥이에게 물어보기"
                            android:textColorHint="@color/font_color3"
                            android:textSize="16sp"
                            android:fontFamily="@font/pretendard_regular"
                            android:background="@android:color/transparent"
                            android:inputType="text"
                            android:maxLines="1"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/btn_plus"
                            app:layout_constraintEnd_toStartOf="@id/btn_send" />

                        <ImageButton
                            android:id="@+id/btn_send"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_send_button"
                            android:contentDescription="전송"
                            android:src="@drawable/ic_chat_arrow_up"
                            android:padding="8dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- 이전 대화 레이블 -->
                <TextView
                    android:id="@+id/tv_chat_history_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="24dp"
                    android:text="@string/chat_history"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- 대화 없을 때 empty state -->
                <TextView
                    android:id="@+id/tv_chat_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:text="@string/chat_empty"
                    android:textColor="@color/font_color2"
                    android:textSize="12sp"
                    android:fontFamily="@font/pretendard_regular"
                    android:gravity="center"
                    android:visibility="gone" />

                <!-- 카테고리 필터 -->
                <HorizontalScrollView
                    android:id="@+id/scroll_chips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:scrollbars="none">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="4dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MJCN.ChatCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="전체" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MJCN.ChatCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="학사공지" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MJCN.ChatCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="수강·졸업" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MJCN.ChatCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="장학·등록금" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MJCN.ChatCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="공모전" />

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MJCN.ChatCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="취업·진로" />
                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <!-- 이전 대화 목록 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_chat_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
