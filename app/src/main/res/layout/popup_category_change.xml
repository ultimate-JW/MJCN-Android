<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="26dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="변경할 카테고리 선택"
                android:textSize="14sp"
                android:fontFamily="@font/pretendard_bold"
                android:textColor="@color/font_color1" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_academic"
                style="@style/Widget.MJCN.ChatCategoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="학사공지" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_course"
                style="@style/Widget.MJCN.ChatCategoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="수강·졸업" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_scholarship"
                style="@style/Widget.MJCN.ChatCategoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="장학·등록금" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_contest"
                style="@style/Widget.MJCN.ChatCategoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="공모전" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_career"
                style="@style/Widget.MJCN.ChatCategoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="취업·진로" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</layout>
